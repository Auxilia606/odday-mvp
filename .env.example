# PostHog 연동 (MVP 문서 섹션 19)
# 이 파일을 .env 로 복사한 뒤 PostHog 프로젝트 값으로 채운다.
#   cp .env.example .env
#
# 값이 비어 있으면 PostHog 수집은 비활성화되고 console/localStorage만 동작한다.
# (Project API Key는 클라이언트에 노출되는 공개 키다 — 비밀 키가 아니다.)

VITE_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 지역에 맞게 선택 (미국: https://us.i.posthog.com, EU: https://eu.i.posthog.com)
VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
